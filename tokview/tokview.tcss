/* tokview.tcss — Phase 2: multi-session terminal-host + 3-pane layout */

#main {
    height: 1fr;
    width: 100%;
}

Sidebar {
    width: 20%;
    height: 100%;
}

#terminal-host {
    width: 1fr;
    height: 100%;
}

#terminal-host > PtyTerminalWidget {
    width: 100%;
    height: 100%;
}

UsagePanel {
    width: 30%;
    height: 100%;
}

StatusBar {
    dock: bottom;
}
